{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE"
  },
  "deploy": {
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "httpHealthCheck": {
      "path": "/healthz",
      "port": 3000,
      "initialDelaySeconds": 60,
      "periodSeconds": 30,
      "timeoutSeconds": 10
    }
  }
}
